# Copy this file to `.env` and fill in your keys.
# NEVER commit `.env` or paste secrets into source files.

# Image provider: pollinations (default) | openai
IMAGE_PROVIDER=pollinations

# free = image.pollinations.ai (no balance needed)
# gen  = gen.pollinations.ai (needs API key + pollen balance; auto-falls back to free on 402)
POLLINATIONS_MODE=free

# Optional — only required for POLLINATIONS_MODE=gen
# POLLINATIONS_API_KEY=sk_your_pollinations_key
# POLLINATIONS_IMAGE_MODEL=flux

# OpenAI (only if IMAGE_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here

PORT=3001

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
